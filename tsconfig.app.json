{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Alias */
    "baseUrl": ".",
    "paths": {
      "#/*": ["./src/*"],
      "#client/*": ["./src/client/*"],
      "#server/*": ["./src/server/*"],
      "#store/*": ["./src/store/*"],
      "#game/*": ["./src/game/*"],
      "#transport/*": ["./src/transport/*"],
      "#shared/*": ["./src/shared/*"]
    },
    "noUncheckedIndexedAccess": true,
    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
